{
  "type": "menu",
  "label": "Configuracion del Agente",
  "domains": {
    "LLM_MODELS": "models.properties",
    "LLM_PROVIDERS_URL": "providers_urls.properties",
    "LLM_PROVIDERS_APIKEY": "providers_apikeys.properties"
  },  
  "childs": [
    {
      "type": "menu",
      "label": "Configuración - modelo de conversación",
      "childs": [
        {
          "type": "combo",
          "childs": "LLM_PROVIDERS_URL",
          "label": "URL del proveedor (conversación)",
          "variableName": "CONVERSATION_PROVIDER_URL",
          "actionName": "CHANGE_CONVERSATION_PROVIDER"
        },
        {
          "type": "combo",
          "label": "API Key (conversación)",
          "variableName": "CONVERSATION_PROVIDER_API_KEY",
          "actionName": "CHANGE_CONVERSATION_PROVIDER",
          "childs": "LLM_PROVIDERS_APIKEY"
        },
        {
          "type": "selectoption",
          "label": "Seleccionar Modelo (conversación)",
          "variableName": "CONVERSATION_MODEL_ID",
          "actionName": "CHANGE_CONVERSATION_MODEL",
          "childs": "LLM_MODELS"
        }
      ]
    },
    {
      "type": "menu",
      "label": "Configuracion - modelo memoria",
      "childs": [
        {
          "type": "combo",
          "childs": "LLM_PROVIDERS_URL",
          "label": "URL del proveedor (memoria)",
          "variableName": "MEMORY_PROVIDER_URL",
          "actionName": "CHANGE_MEMORY_PROVIDER"
        },
        {
          "type": "combo",
          "label": "API Key (memoria)",
          "variableName": "MEMORY_PROVIDER_API_KEY",
          "actionName": "CHANGE_MEMORY_PROVIDER",
          "childs": "LLM_PROVIDERS_APIKEY"
        },
        {
          "type": "selectoption",
          "label": "Seleccionar Modelo (memoria)",
          "variableName": "MEMORY_MODEL_ID",
          "actionName": "CHANGE_MEMORY_MODEL",
          "childs": "LLM_MODELS"
        }
      ]
    },
    {
      "type": "menu",
      "label": "Configuración de Telegram",
      "childs": [
        {
          "type": "inputstring",
          "label": "Telegram API Key",
          "variableName": "TELEGRAM_API_KEY"
        },
        {
          "type": "inputstring",
          "label": "ID de Chat Autorizado (User ID)",
          "variableName": "TELEGRAM_CHAT_ID"
        }
      ]
    },
    {
      "type": "menu",
      "label": "Configuración de Email",
      "childs": [
        {
          "type": "inputstring",
          "label": "Servidor IMAP (Entrada)",
          "variableName": "EMAIL_IMAP_HOST"
        },
        {
          "type": "inputstring",
          "label": "Servidor SMTP (Salida)",
          "variableName": "EMAIL_SMTP_HOST"
        },
        {
          "type": "inputstring",
          "label": "Usuario / Email",
          "variableName": "EMAIL_USER"
        },
        {
          "type": "inputstring",
          "label": "Contraseña",
          "variableName": "EMAIL_PASSWORD"
        },
        {
          "type": "inputstring",
          "label": "Email del Dueño (Remitente Autorizado)",
          "variableName": "EMAIL_AUTHORIZED_SENDER"
        }
      ]
    },
    {
      "type": "menu",
      "label": "Configuracion para el DocMapper",
      "childs": [
        {
          "type": "menu",
          "label": "Modelo de Razonamiento (Estructura)",
          "childs": [
            {
              "type": "combo",
              "childs": "LLM_PROVIDERS_URL",
              "label": "URL del proveedor (documentos razonamiento)",
              "variableName": "DOCMAPPER_REASONING_PROVIDER_URL"
            },
            {
              "type": "combo",
              "label": "API Key (documentos razonamiento)",
              "variableName": "DOCMAPPER_REASONING_PROVIDER_API_KEY",
              "childs": "LLM_PROVIDERS_APIKEY"
            },
            {
              "type": "selectoption",
              "label": "Seleccionar Modelo (documentos razonamiento)",
              "variableName": "DOCMAPPER_REASONING_MODEL_ID",
              "childs": "LLM_MODELS"
            }
          ]
        },
        {
          "type": "menu",
          "label": "Modelo Básico (Resumen y Categorización)",
          "childs": [
            {
              "type": "combo",
              "childs": "LLM_PROVIDERS_URL",
              "label": "URL del proveedor (documentos basico)",
              "variableName": "DOCMAPPER_BASIC_PROVIDER_URL"
            },
            {
              "type": "combo",
              "label": "API Key (documentos basico)",
              "variableName": "DOCMAPPER_BASIC_PROVIDER_API_KEY",
              "childs": "LLM_PROVIDERS_APIKEY"
            },
            {
              "type": "selectoption",
              "label": "Seleccionar Modelo (documentos basico)",
              "variableName": "DOCMAPPER_BASIC_MODEL_ID",
              "childs": "LLM_MODELS"
            }
          ]
        }
      ]
    },
    {
      "type": "inputstring",
      "label": "Brave Search API Key",
      "variableName": "BRAVE_SEARCH_API_KEY"
    },
    {
      "type": "action",
      "label": "Modelos",
      "actionName": "OPEN_MODELS_EDITOR"
    },
    {
      "type": "action",
      "label": "Proveedores",
      "actionName": "OPEN_PROVIDERS_URL_EDITOR"
    },
    {
      "type": "action",
      "label": "API Keys",
      "actionName": "OPEN_PROVIDERS_APIKEY_EDITOR"
    },
    {
      "type": "menu",
      "label": "Debug",
      "childs": [
        {
          "type": "inputstring",
          "label": "Puerto del servicio web de H2",
          "variableName": "H2_WEBPORT"
        },
        {
          "type": "action",
          "label": "Compactar conversación",
          "actionName": "COMPACT_CONVERSATION"
        }
      ]
    }
  ]
}
